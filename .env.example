# Kopier til .env og fyll inn. Alt har fornuftige defaults — appen kjører
# helt fint UTEN OpenRouter-nøkkel (da faller kuratering tilbake på nyeste
# saker, og oversettelse hoppes over og beholder originalteksten).

# --- LLM ---
# Provider: auto | openrouter | claude_cli | none
#   auto (anbefalt): bruker OpenRouter hvis nøkkel er satt under, ellers en
#   lokal innlogget Claude-session (claude-CLI) hvis den finnes — perfekt for
#   localhost uten å sette opp API-nøkkel. Faller tilbake til demo-modus ellers.
LLM_PROVIDER=auto

# OpenRouter (brukes på server / når nøkkel er satt). https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Modeller (OpenRouter-format "leverandør/modell"). Haiku er billig til oversettelse.
CURATE_MODEL=anthropic/claude-haiku-4.5
TRANSLATE_MODEL=anthropic/claude-haiku-4.5

# Lokal Claude-session (claude_cli). Tom = CLI-ens standardmodell.
# TIPS: sett til en rask modell (f.eks. haiku) — oversettelse trenger ikke Opus,
# og standardmodellen din er kanskje treg/dyr for 8000-tegns brødtekster.
CLAUDE_MODEL=

# Oversettelse: batch flere artikler per LLM-kall (amortiserer claude-CLI-oppstart),
# og kjør batchene parallelt.
TRANSLATE_CONCURRENCY=4      # antall batch-kall samtidig
TRANSLATE_BATCH_MAX=5        # maks artikler per kall
TRANSLATE_BATCH_CHARS=9000   # maks tegn samlet per kall

# --- Avis / pipeline ---
# Hvor ofte bakgrunns-pollingen kjører (minutter)
POLL_MINUTES=30
# Hvor mange saker som havner i avisa
FRONT_PAGE_SIZE=12
# Maks nye saker som fulltekst-hentes per kjør (forsidesakene garanteres uansett)
CONTENT_FETCH_LIMIT=40
# Bruk Playwright-browser som fallback for JS-tunge sider (1/0)
USE_PLAYWRIGHT=true
# Utelat saker bak betalingsmur (oppdaget via isAccessibleForFree + markører)
FILTER_PAYWALLED=true
# Tittel på avisa
PAPER_TITLE=Morgenavisa
# Avisas målspråk (ISO-kode). Innhold oversettes TIL dette, og grensesnittet
# vises på det (lokalisert for no/en; andre språk faller tilbake til norsk UI).
PAPER_LANG=no
# Kildespråk du vil la stå URØRT selv om de avviker fra målspråket (komma-
# separert). Tom = målspråket alene styrer hva som oversettes. Kan endres i
# innstillinger. F.eks. PAPER_LANG=no + TRANSLATE_SKIP_LANGS=en gir norsk avis
# der engelske kilder vises på engelsk.
TRANSLATE_SKIP_LANGS=
# Redaksjonell profil — styrer hva som kurateres inn
PREFERENCES=Generelle nyheter, teknologi, klima og vitenskap. Vekt på analyse og bakgrunn fremfor kjendis, sport og rene meningsinnlegg.

# --- Innlogging (admin) ---
# Beskytter /settings, kilder, tilbakemelding og oppdater-knappen. Tom = ingen
# innlogging (alt åpent — greit lokalt / bak VPN). Sett et passord ved eksponering.
ADMIN_PASSWORD=
# Hemmelighet for cookie-signering (valgfri; faller tilbake på ADMIN_PASSWORD).
SESSION_SECRET=

# --- DB ---
DATABASE_URL=sqlite:///./avisa.db
