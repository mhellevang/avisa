# Copy to .env and fill in. Everything has sensible defaults — the app runs
# perfectly fine WITHOUT an OpenRouter key (curation then falls back to the
# latest stories, and translation is skipped, keeping the original text).

# --- LLM ---
# Provider: auto | openrouter | claude_cli | none
#   auto (recommended): uses OpenRouter if a key is set below, otherwise a
#   local logged-in Claude session (claude CLI) if present — perfect for
#   localhost without setting up an API key. Falls back to demo mode otherwise.
LLM_PROVIDER=auto

# OpenRouter (used on a server / when a key is set). https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Models (OpenRouter format "provider/model"). Haiku is cheap for translation.
CURATE_MODEL=anthropic/claude-haiku-4.5
TRANSLATE_MODEL=anthropic/claude-haiku-4.5

# Local Claude session (claude_cli). Empty = the CLI's default model.
# TIP: set a fast model (e.g. haiku) — translation doesn't need Opus, and your
# default model may be slow/expensive for 8000-char bodies.
CLAUDE_MODEL=

# Translation: batch several articles per LLM call (amortizes claude-CLI
# startup), and run the batches in parallel.
TRANSLATE_CONCURRENCY=4      # number of batch calls at once
TRANSLATE_BATCH_MAX=5        # max articles per call
TRANSLATE_BATCH_CHARS=9000   # max chars total per call

# --- Paper / pipeline ---
# IANA timezone for displayed dates/times (stored times are UTC). Set this to
# your local zone or the clock on the page will be off (e.g. 2h behind in
# Norwegian summer time). Examples: Europe/Oslo, Europe/London, America/New_York.
TIMEZONE=Europe/Oslo
# How often the background polling runs (minutes)
POLL_MINUTES=30
# How many stories end up in the paper
FRONT_PAGE_SIZE=12
# Max new stories fetched for full text per run (front-page stories are guaranteed regardless)
CONTENT_FETCH_LIMIT=40
# Use the Playwright browser as a fallback for JS-heavy pages (1/0)
USE_PLAYWRIGHT=true
# Exclude stories behind a paywall (detected via isAccessibleForFree + markers)
FILTER_PAYWALLED=true
# The paper's title
PAPER_TITLE=The Morning Paper
# The paper's target language (ISO code). Content is translated TO this, and the
# interface is shown in it (localized for en/no; other languages fall back to
# the English UI).
PAPER_LANG=en
# Source languages you want left UNTOUCHED even if they differ from the target
# language (comma-separated). Empty = the target language alone decides what
# gets translated. Can be changed in settings. E.g. PAPER_LANG=no +
# TRANSLATE_SKIP_LANGS=en gives a Norwegian paper where English sources stay English.
TRANSLATE_SKIP_LANGS=
# Editorial profile — drives what gets curated in
PREFERENCES=General news, technology, climate and science. Weight on analysis and background over celebrity, sports and pure opinion pieces.

# --- Login (admin) ---
# Protects /settings, sources, feedback and the refresh button. Empty = no
# login (everything open — fine locally / behind a VPN). Set a password when exposed.
ADMIN_PASSWORD=
# Secret for cookie signing (optional; falls back to ADMIN_PASSWORD).
SESSION_SECRET=

# --- DB ---
DATABASE_URL=sqlite:///./avisa.db
