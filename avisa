#!/usr/bin/env bash
# Simple start/stop for Avisa (local run).
#   ./avisa start     start in the background
#   ./avisa stop      stop
#   ./avisa restart   stop + start
#   ./avisa status    is it running?
#   ./avisa logs      follow the log (Ctrl+C to exit)
#   ./avisa setup     interactive setup wizard (title, profile, sources)
#   ./avisa dev       run in the foreground with auto-reload (for development)
set -euo pipefail

cd "$(dirname "$0")"

PORT="${PORT:-8000}"
PIDFILE=".avisa.pid"
LOGFILE="avisa.log"
VENV=".venv"

# Pick a compatible Python (SQLModel can't handle 3.14 yet).
pick_python() {
  for c in python3.13 python3.12 python3.11 python3; do
    if command -v "$c" >/dev/null 2>&1; then echo "$c"; return; fi
  done
  echo "No python3 found" >&2; exit 1
}

ensure_venv() {
  if [ ! -d "$VENV" ]; then
    local py; py="$(pick_python)"
    echo "→ Creating virtual environment with $py …"
    "$py" -m venv "$VENV"
  fi
  # Install/upgrade dependencies if anything is missing (e.g. after new
  # packages have been added to requirements.txt).
  if ! "$VENV/bin/python" -c "import playwright, trafilatura" >/dev/null 2>&1; then
    echo "→ Installing dependencies …"
    "$VENV/bin/pip" install -q -r requirements.txt
    echo "→ Downloading Chromium for Playwright (one-time job) …"
    "$VENV/bin/python" -m playwright install chromium
    echo "→ Done."
  fi
  if [ ! -f .env ]; then
    cp .env.example .env
    echo "→ Created .env from template (runs in demo mode until you add OPENROUTER_API_KEY)."
  fi
}

is_running() {
  [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null
}

start() {
  if is_running; then
    echo "Avisa is already running (pid $(cat "$PIDFILE")) → http://localhost:$PORT"
    return
  fi
  ensure_venv
  echo "→ Starting Avisa on http://localhost:$PORT …"
  nohup "$VENV/bin/uvicorn" app.main:app --host 0.0.0.0 --port "$PORT" \
    >"$LOGFILE" 2>&1 &
  echo $! >"$PIDFILE"
  sleep 1
  if is_running; then
    echo "✓ Up (pid $(cat "$PIDFILE")). Log: ./avisa logs"
  else
    echo "✗ Failed to start. See $LOGFILE"; exit 1
  fi
}

stop() {
  if is_running; then
    kill "$(cat "$PIDFILE")" && rm -f "$PIDFILE"
    echo "✓ Stopped."
  else
    rm -f "$PIDFILE"
    echo "Avisa was not running."
  fi
}

case "${1:-}" in
  start)   start ;;
  stop)    stop ;;
  restart) stop; start ;;
  status)
    if is_running; then echo "Running (pid $(cat "$PIDFILE")) → http://localhost:$PORT"
    else echo "Stopped."; fi ;;
  logs)    touch "$LOGFILE"; tail -f "$LOGFILE" ;;
  setup)   ensure_venv; exec "$VENV/bin/python" -m app.setup_wizard ;;
  dev)     ensure_venv; exec "$VENV/bin/uvicorn" app.main:app --reload --port "$PORT" ;;
  *)
    echo "Usage: ./avisa {start|stop|restart|status|logs|setup|dev}"; exit 1 ;;
esac
